# Production Environment Configuration
# COPY THIS FILE TO .env AND UPDATE VALUES FOR YOUR ENVIRONMENT

# Application Settings
APP_NAME=Stream Backend API
APP_VERSION=1.0.0
DEBUG=False

# Database Configuration
POSTGRES_DB=stream_db
POSTGRES_USER=stream_user
POSTGRES_PASSWORD=stream_password
DB_PORT=5432
DATABASE_ECHO=False

# API Server Configuration
API_PORT=8000

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production-please
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Security
SERVER_HOST=0.0.0.0
SERVER_PORT=8000


#Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

ADMIN_EMAILS=admin@seninapp.com,ozenc@seninapp.com